{
  "Auth": {
    "Jwt": {
      "Issuer": "company-auth",
      "Audience": "company-services",
      "SecretKey": "CHANGE_ME_WITH_A_LONG_SECRET_KEY_AT_LEAST_32_CHARS",
      "ExpirationMinutes": 60,
      "RequireHttpsMetadata": true
    },
    "Redis": {
      "ValidateRevokedTokens": true,
      "ValidateActiveSessions": false
    }
  },
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=company_service;Username=postgres;Password=postgres"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "company-service:"
  },
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "company_service"
  },
  "AllowedHosts": "*"
}
